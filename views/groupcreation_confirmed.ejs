<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Group created and confirmed</title>
    <meta charset="UTF-8">
    <meta name="description" content="Group creation confirmed">
    <meta name="keywords" content="Group created, group confirmed, add friends, invite friends, share link, change group name, upload group image">
    <meta name="author" content="Group 4">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/styles_questions.css">
    <link rel="stylesheet" href="/css/styles_group.css">
  </head>
  <body>
    <%- include('partials/navbar') %>
    <header></header>
    <main>
      <h1>Your group "<%= group.name %>" has been created!</h1>
      <p>Now you can add your friends by searching for them or sending them the link to join the group.</p>

      <div class="groupfriendContainer">

        <!-- Invite friends section -->
        <section class="addfriendContainer">
          <form action="/groups/<%= group.id %>/invite" method="post">
            <label for="friendSearch">Search for a friend:</label>
            <input type="search" id="friendSearch" name="friendSearch" placeholder="Search your friend...">
            <br>
            <p>or</p>
            <p>Send the link to a friend via e-mail:</p>
            <label for="friendemail">Your friend's e-mail address:</label><br>
            <input type="email" id="friendemail" name="friendemail" required><br>
            <label for="friendmsg">A short message (optional):</label><br>
            <input type="text" id="friendmsg" name="friendmsg"><br>
            <input type="submit" value="Share link">
          </form>
        </section>

        <!-- Change group name and image section -->
        <section class="groupNameImgContainer">
          <figure>
            <img src="<%= group.image || '/images/default-group.jpg' %>" alt="<%= group.name %> group image">
          </figure>
          <div>
            <form action="/groups/<%= group.id %>/update-name" method="post">
              <label for="changeGroupname">Change your group name: </label><br>
              <input type="text" id="changeGroupname" name="changeGroupname" value="<%= group.name %>"><br>
              <input type="submit" value="Change your group name">
            </form>

            <form action="/groups/<%= group.id %>/upload-image" method="post" enctype="multipart/form-data">
              <label for="uploadGroupImg">Upload a group image: </label><br>
              <input type="file" id="uploadGroupImg" name="uploadGroupImg" accept="image/*"><br>
              <input type="submit" value="Upload a group image">
            </form>
          </div>
        </section>

      </div>
    </main>
    <footer></footer>
  </body>
</html>