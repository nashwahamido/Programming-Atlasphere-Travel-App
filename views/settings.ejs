<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/settings.css">
</head>
<body>

<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="settings-page">
  <h1>Settings</h1>

  <div class="settings-container">

    <!-- Left sidebar tabs -->
    <div class="settings-sidebar">
      <button class="settings-tab active" onclick="showTab(event, 'manageInfo')">Manage your information</button>
      <button class="settings-tab" onclick="showTab(event, 'visitedLocations')">Modify Visited Location</button>
      <button class="settings-tab" onclick="showTab(event, 'manageGroups')">Manage your groups</button>
      <button class="settings-tab" onclick="showTab(event, 'deleteAccount')">Delete Account</button>
    </div>

    <!-- Right content panels -->
    <div class="settings-content">

      <!-- Manage your information -->
      <div id="manageInfo" class="settings-panel active">
        <form action="/users/update" method="post">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="<%= user ? user.username : '' %>">
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="<%= user ? user.email : '' %>">
          </div>
          <div class="form-group">
            <label for="phone">Phone</label>
            <div class="phone-row">
              <input type="text" id="phoneCode" name="phoneCode" placeholder="+353" class="phone-code">
              <input type="tel" id="phone" name="phone" value="<%= user ? (user.phonenumber || '') : '' %>">
            </div>
          </div>
          <div class="form-group">
            <label for="gender">Gender</label>
            <select id="gender" name="gender">
              <option value="">Select</option>
              <option value="m" <%= user && user.FIDgender === 1 ? 'selected' : '' %>>Male</option>
              <option value="f" <%= user && user.FIDgender === 2 ? 'selected' : '' %>>Female</option>
              <option value="d" <%= user && user.FIDgender === 3 ? 'selected' : '' %>>Diverse</option>
            </select>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-save">Save</button>
          </div>
        </form>
      </div>

      <!-- Modify visited locations -->
      <div id="visitedLocations" class="settings-panel">
        <form action="/users/update-locations" method="post" id="locationsForm">

          <h3>Change Visited Countries:</h3>
          <div class="search-bar">
            <span class="search-icon">🔍</span>
            <input type="search" id="countrySearch" placeholder="Search countries..."
              oninput="filterCountries(this.value)">
            <span class="clear-icon" onclick="document.getElementById('countrySearch').value=''; filterCountries('');">⊗</span>
          </div>
          <div class="location-grid" id="countryGrid">
            <% const allCountries = typeof allCountriesData !== 'undefined' ? allCountriesData : []; %>
            <% allCountries.forEach(function(country) { %>
              <% const isChecked = user && user.visitedCountries && user.visitedCountries.includes(country.code); %>
              <label class="location-card <%= isChecked ? 'location-card--checked' : '' %>"
                data-name="<%= country.name.toLowerCase() %>">
                <input type="checkbox" name="countries[]" value="<%= country.code %>"
                  <%= isChecked ? 'checked' : '' %>
                  onchange="this.closest('.location-card').classList.toggle('location-card--checked', this.checked)">
                <span class="location-flag"><%= country.flag %></span>
                <span class="location-name"><%= country.name %></span>
              </label>
            <% }) %>
          </div>

          <hr style="margin: 24px 0; border-color: var(--border, #e0e0e0);">

          <h3>Change Visited Cities:</h3>
          <div class="search-bar">
            <span class="search-icon">🔍</span>
            <input type="search" id="citySearch" placeholder="Search cities..."
              oninput="filterCities(this.value)">
            <span class="clear-icon" onclick="document.getElementById('citySearch').value=''; filterCities('');">⊗</span>
          </div>
          <div class="location-grid" id="cityGrid">
            <% allCountries.forEach(function(country) { %>
              <% country.cities.forEach(function(cityName) { %>
                <% const isChecked = user && user.visitedCities && user.visitedCities.includes(cityName); %>
                <label class="location-card <%= isChecked ? 'location-card--checked' : '' %>"
                  data-name="<%= cityName.toLowerCase() %>">
                  <input type="checkbox" name="cities[]" value="<%= cityName %>"
                    <%= isChecked ? 'checked' : '' %>
                    onchange="this.closest('.location-card').classList.toggle('location-card--checked', this.checked)">
                  <span class="location-flag"><%= country.flag %></span>
                  <span class="location-name"><%= cityName %></span>
                </label>
              <% }) %>
            <% }) %>
          </div>

          <div class="form-actions" style="margin-top: 24px;">
            <button type="submit" class="btn-save">Save</button>
          </div>
        </form>
      </div>

      <!-- Manage your groups -->
      <div id="manageGroups" class="settings-panel">
        <div class="search-bar">
          <span class="search-icon">🔍</span>
          <input type="search" placeholder="Search" oninput="filterGroups(this.value)">
          <span class="clear-icon">⊗</span>
        </div>
        <div class="groups-container">
          <div class="groups-list" id="groupsList">
            <% const groupList = typeof groups !== 'undefined' && groups ? groups : [
              { id: 1, name: 'Prague' },
              { id: 2, name: 'Rome' },
              { id: 3, name: 'Dublin' }
            ]; %>
            <% groupList.forEach(function(group) { %>
              <div class="group-row" data-name="<%= group.name.toLowerCase() %>">
                <button class="group-name-btn"
                  onclick="selectGroup(<%= group.id %>, '<%= group.name %>', this)">
                  <%= group.name %>
                </button>
              </div>
            <% }) %>
          </div>
          <div class="group-actions">
            <button class="btn-action" onclick="deleteSelectedGroup()">Delete Group</button>
            <button class="btn-action" onclick="showRenameForm()">Change Name</button>
            <button class="btn-action">Modify Interests</button>
          </div>
        </div>

        <!-- Rename form (hidden by default) -->
        <div id="renameForm" style="display:none; margin-top:20px;">
          <form id="renameGroupForm" method="post">
            <div class="form-group">
              <label>New group name</label>
              <input type="text" id="newGroupName" name="newName" placeholder="Enter new name">
            </div>
            <div class="form-actions" style="gap:8px;">
              <button type="submit" class="btn-save">Save Name</button>
              <button type="button" class="btn-action" onclick="hideRenameForm()">Cancel</button>
            </div>
          </form>
        </div>

        <p id="noGroupSelected" style="color:#aaa; font-size:13px; margin-top:12px; display:none;">
          Please select a group first.
        </p>
      </div>

      <!-- Delete account -->
      <div id="deleteAccount" class="settings-panel">
        <p class="delete-msg">Do you wish to delete your Atlasphere account?</p>
        <p style="font-size:14px; color:#aaa; margin-bottom:24px; text-align:center;">
          This action is permanent and cannot be undone. Type <strong>DELETE</strong> below to confirm.
        </p>
        <div style="max-width:320px; margin:0 auto;">
          <input type="text" id="deleteConfirmInput" placeholder="Type DELETE to confirm"
            oninput="checkDeleteInput(this.value)"
            style="width:100%; padding:12px 16px; border-radius:8px; border:2px solid #dce6f0;
                   font-size:15px; text-align:center; margin-bottom:16px; outline:none;
                   background: var(--input-bg, #fff); color: var(--text, #0B3856);">
          <div class="delete-actions" style="flex-direction:column; align-items:center; gap:10px;">
            <form action="/users/delete" method="post" style="width:100%;">
              <button type="submit" id="deleteConfirmBtn" class="btn-confirm"
                disabled style="opacity:0.4; cursor:not-allowed; width:100%;">
                Permanently Delete Account
              </button>
            </form>
            <button class="btn-cancel" onclick="showTab(event, 'manageInfo')" style="width:100%;">
              Cancel
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  function showTab(e, tabId) {
    document.querySelectorAll('.settings-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
    e.target.classList.add('active');
    var input = document.getElementById('deleteConfirmInput');
    if (input) { input.value = ''; checkDeleteInput(''); }
  }

  function checkDeleteInput(value) {
    var btn = document.getElementById('deleteConfirmBtn');
    var input = document.getElementById('deleteConfirmInput');
    if (value === 'DELETE') {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
      input.style.borderColor = '#e74c3c';
    } else {
      btn.disabled = true;
      btn.style.opacity = '0.4';
      btn.style.cursor = 'not-allowed';
      input.style.borderColor = '#dce6f0';
    }
  }

  function initLocationGrids() {
    // Hide all unchecked cards by default — only show checked ones and search results
    document.querySelectorAll('#countryGrid .location-card').forEach(function(card) {
      if (!card.querySelector('input').checked) {
        card.style.display = 'none';
      }
    });
    document.querySelectorAll('#cityGrid .location-card').forEach(function(card) {
      if (!card.querySelector('input').checked) {
        card.style.display = 'none';
      }
    });
  }

  function filterCountries(query) {
    var q = query.toLowerCase();
    document.querySelectorAll('#countryGrid .location-card').forEach(function(card) {
      if (q.length < 2) {
        // Show only checked ones when query is too short
        card.style.display = card.querySelector('input').checked ? '' : 'none';
      } else {
        card.style.display = card.dataset.name.includes(q) ? '' : 'none';
      }
    });
  }

  function filterCities(query) {
    var q = query.toLowerCase();
    document.querySelectorAll('#cityGrid .location-card').forEach(function(card) {
      if (q.length < 2) {
        card.style.display = card.querySelector('input').checked ? '' : 'none';
      } else {
        card.style.display = card.dataset.name.includes(q) ? '' : 'none';
      }
    });
  }

  var selectedGroupId = null;
  var selectedGroupName = null;

  function selectGroup(id, name, btn) {
    selectedGroupId = id;
    selectedGroupName = name;
    document.querySelectorAll('.group-name-btn').forEach(function(b) {
      b.style.background = '';
      b.style.color = '';
      b.style.borderColor = '';
    });
    btn.style.background = '#0B3856';
    btn.style.color = 'white';
    btn.style.borderColor = '#0B3856';
    document.getElementById('noGroupSelected').style.display = 'none';
    hideRenameForm();
  }

  function deleteSelectedGroup() {
    if (!selectedGroupId) {
      document.getElementById('noGroupSelected').style.display = 'block';
      return;
    }
    if (confirm('Are you sure you want to delete "' + selectedGroupName + '"?')) {
      fetch('/groups/delete/' + selectedGroupId, { method: 'POST' })
        .then(function() { window.location.reload(); });
    }
  }

  function showRenameForm() {
    if (!selectedGroupId) {
      document.getElementById('noGroupSelected').style.display = 'block';
      return;
    }
    document.getElementById('newGroupName').value = selectedGroupName;
    document.getElementById('renameGroupForm').action = '/groups/rename/' + selectedGroupId;
    document.getElementById('renameForm').style.display = 'block';
    document.getElementById('noGroupSelected').style.display = 'none';
  }

  function hideRenameForm() {
    document.getElementById('renameForm').style.display = 'none';
  }

  function filterGroups(query) {
    document.querySelectorAll('.group-row').forEach(function(row) {
      row.style.display = row.dataset.name.includes(query.toLowerCase()) ? '' : 'none';
    });
  }

  // Run on page load
  initLocationGrids();
</script>

</body>
</html>