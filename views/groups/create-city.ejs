<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choose Cities - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert landscape"></div>
    <div class="framed-box__content">
      <div class="group-creation-content">
        <h1>Which cities in &ldquo;<%= typeof countryFlag !== 'undefined' ? countryFlag + ' ' : '' %><%= typeof countryName !== 'undefined' ? countryName : 'Country' %>&rdquo;?</h1>
        <p>Select at least one city</p>

        <div class="search-input" style="margin: 24px auto;">
          <span class="search-icon">&#128269;</span>
          <input type="text" id="citySearch" placeholder="Search cities...">
        </div>

        <form action="/groups/create/days" method="get" id="cityForm">
          <input type="hidden" name="country" value="<%= typeof countryName !== 'undefined' ? countryName : '' %>">
          <input type="hidden" name="cities" id="selectedCities" value="">

          <div class="destination-grid" id="cityGrid">
            <% if (typeof cities !== 'undefined' && cities.length > 0) { %>
              <% cities.forEach(function(city) { %>
                <div class="destination-card" data-value="<%= city %>">
                  <div class="card-flag" style="font-size: 28px;">&#127961;</div>
                  <span class="card-name"><%= city %></span>
                </div>
              <% }); %>
            <% } else { %>
              <p style="text-align: center; color: rgba(255,255,255,0.6); grid-column: 1 / -1; padding: 40px 0;">
                No cities found. <a href="/groups/create/country" style="color: #E8933A;">Go back and select a country</a>.
              </p>
            <% } %>
          </div>

          <div class="setup-actions" style="margin-top: 32px;">
            <a href="/groups/create/country" class="btn btn-secondary" style="margin-right: 12px;">Back</a>
            <button type="submit" class="btn btn-primary" id="nextBtn" disabled>Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  var cards = document.querySelectorAll('#cityGrid .destination-card');
  var selectedInput = document.getElementById('selectedCities');
  var nextBtn = document.getElementById('nextBtn');

  function updateSelected() {
    var selected = [];
    cards.forEach(function(card) {
      if (card.classList.contains('selected')) {
        selected.push(card.dataset.value);
      }
    });
    selectedInput.value = selected.join(',');
    nextBtn.disabled = selected.length === 0;
  }

  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      card.classList.toggle('selected');
      updateSelected();
    });
  });

  document.getElementById('citySearch').addEventListener('input', function(e) {
    var q = e.target.value.toLowerCase();
    cards.forEach(function(card) {
      var name = card.querySelector('.card-name').textContent.toLowerCase();
      card.style.display = name.includes(q) ? '' : 'none';
    });
  });

  document.getElementById('cityForm').addEventListener('submit', function(e) {
    if (!selectedInput.value) {
      e.preventDefault();
      alert('Please select at least one city.');
    }
  });
</script>
</body>
</html>
