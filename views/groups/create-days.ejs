            <input type="range" min="1" max="365" value="50" class="slider" id="slideRange">
            <p>Length: <span id="length"></span> days</p>
        </div>
        <!-- JS code for animating the slider showing the number of days -->
        <script src="/js/groupTabs.js"></script>

        <a href="create-confirm.ejs">Next</a>

    </main>

    <!-- <form action="/groups/create/confirm" method="get">
