<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Question: Which countries have you visited?</title>

    <meta charset="UTF-8">
    <meta name="description" content="Question: Which countries have you visited?">
    <meta name="keywords" content="Question: Which countries have you visited?">
    <meta name="author" content="Group 4">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="../css/styles.css">
    <link rel="stylesheet" href="../css/styles_questions.css">
  </head>

  <body>
    <nav class="navbar">
      <a href="#"><img src="#" alt="logo icon of Atlasphere"></a>
      <a href="#">Atlasphere</a>
      <a href="#" class="right">Home</a>
      <a href="#" class="right">Profile</a>
      <a href="#" class="right">Settings</a>
      <a href="#" class="right">Sign out</a>
    </nav>

    <header></header>

    <main>
      <section>
        <h1>Which countries have you visited?</h1>
        <a href="qcitiesvisited.html">Skip</a><br>

        <form>
          <input
            type="search"
            id="countrysearch"
            name="countrysearch"
            placeholder="Search..."
          ><br>
        </form>

        <div class="locationContainer">
          <% countries.forEach((country) => { %>
            <div class="locationCard">
              <figure>
                <img
                  src="<%= country.image %>"
                  alt="<%= country.name %>"
                  class="locationImg"
                >
              </figure>
              <div class="locationCardText">
                <h4><%= country.name %></h4>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <a href="qcitiesvisited.html">Next</a><br>
    </main>

    <footer></footer>
  </body>
</html>