<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Countries Visited - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">

  <style>
    /* scrollbar for countries */
    #countryGrid {
      max-height: 420px;
      overflow-y: auto;
      padding-right: 8px;
    }

    #countryGrid::-webkit-scrollbar {
      width: 8px;
    }

    #countryGrid::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.25);
      border-radius: 999px;
    }

    #countryGrid::-webkit-scrollbar-track {
      background: transparent;
    }
  </style>
</head>
<body>
<%- include('../../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/registration-lake.jpg" alt="Lake"></div>
    <div class="framed-box__content">
      <div class="sel-content">
        <div class="sel-header">
          <h1>What countries have you visited?</h1>
          <a href="/setup/cities" class="skip-btn">Skip</a>
        </div>

        <!--search bar -->
        <div class="sel-search">
          <!--input filter for countries-->
          <input type="text" placeholder="Search countries..." id="countrySearch">
        </div>

<form action="/setup/cities" method="get" id="countryForm">
  <div class="flag-grid" id="countryGrid">
    <% if (typeof countries !== 'undefined') { %>
      <% countries.forEach(function(c) { %>
        <label class="flag-card">
          <input type="checkbox" name="countries[]" value="<%= c.code %>">

          <span class="flag-card__img">
            <img
              src="https://flagcdn.com/w80/<%= c.code.toLowerCase() %>.png"
              alt="<%= c.name %>">
          </span>

          <span class="flag-card__name"><%= c.name %></span>
        </label>
      <% }); %>
    <% } %>
  </div>

  <div class="sel-actions">
            <button type="submit" class="btn-next">Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
  var s = localStorage.getItem('atlasphere-theme');
  if (s) document.documentElement.setAttribute('data-theme', s);

  var cards = document.querySelectorAll('#countryGrid .flag-card');
  var searchInput = document.getElementById('countrySearch');

  // Toggle selection via checkbox change
  cards.forEach(function(card) {
    var cb = card.querySelector('input[type="checkbox"]');
    if (cb) {
      cb.addEventListener('change', function() {
        card.classList.toggle('selected', cb.checked);
      });
    }
  });

  // filter countries when typing in search bar
  searchInput.addEventListener('input', function(e) {
    var q = e.target.value.toLowerCase().trim();

    cards.forEach(function(card) {
      var name = card.querySelector('.flag-card__name').textContent.toLowerCase();
      card.classList.toggle('hidden-card', q.length > 0 && !name.includes(q));
    });
  });
</script>
</body>
</html>