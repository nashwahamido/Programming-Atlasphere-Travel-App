<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Countries Visited - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/registration-lake.jpg" alt="Lake"></div>
    <div class="framed-box__content">
      <div class="sel-content">
        <div class="sel-header">
          <h1>What countries have you visited?</h1>
          <a href="/setup/cities" class="skip-btn">Skip</a>
        </div>
        <div class="sel-search"><span>&#128269;</span><input type="text" placeholder="Search countries..." id="countrySearch"></div>
        <form action="/setup/cities" method="get" id="countryForm">
          <div class="flag-grid" id="countryGrid">
            <% if (typeof countries !== 'undefined') { %>
              <% countries.forEach(function(c, i) { %>
                <label class="flag-card<%= i >= 12 ? ' hidden-card' : '' %>" data-index="<%= i %>">
                  <input type="checkbox" name="countries[]" value="<%= c.code %>">
                  <span class="flag-card__img"><%= c.flag %></span>
                  <span class="flag-card__name"><%= c.name %></span>
                </label>
              <% }); %>
            <% } %>
          </div>
          <div class="sel-actions">
            <button type="button" class="btn-load-more" id="loadMoreBtn" style="margin-bottom:12px;">Load more countries</button>
            <button type="submit" class="btn-next">Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
  var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);

  var PAGE_SIZE = 12;
  var visible = PAGE_SIZE;
  var cards = document.querySelectorAll('#countryGrid .flag-card');
  var loadMoreBtn = document.getElementById('loadMoreBtn');

  // Toggle selection via checkbox change (not click, to avoid double-toggle)
  cards.forEach(function(card) {
    var cb = card.querySelector('input[type="checkbox"]');
    if (cb) {
      cb.addEventListener('change', function() {
        card.classList.toggle('selected', cb.checked);
      });
    }
  });

  // Load more
  function updateVisibility() {
    var hiddenCount = 0;
    cards.forEach(function(card) {
      var idx = parseInt(card.dataset.index);
      if (idx < visible) {
        card.classList.remove('hidden-card');
      } else {
        card.classList.add('hidden-card');
        hiddenCount++;
      }
    });
    loadMoreBtn.style.display = hiddenCount > 0 ? '' : 'none';
  }

  loadMoreBtn.addEventListener('click', function() {
    visible += PAGE_SIZE;
    updateVisibility();
  });

  // Search
  document.getElementById('countrySearch').addEventListener('input', function(e) {
    var q = e.target.value.toLowerCase().trim();
    if (q.length > 0) {
      cards.forEach(function(card) {
        var name = card.querySelector('.flag-card__name').textContent.toLowerCase();
        card.classList.toggle('hidden-card', !name.includes(q));
      });
      loadMoreBtn.style.display = 'none';
    } else {
      visible = PAGE_SIZE;
      updateVisibility();
    }
  });

  updateVisibility();
</script>
</body>
</html>
