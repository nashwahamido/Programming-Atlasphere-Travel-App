<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choose Destination - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert landscape"></div>
    <div class="framed-box__content">
      <div class="group-creation-content">
        <h1>What is your destination<br>for your group holiday?</h1>

        <div class="search-input" style="margin: 24px auto;">
          <span class="search-icon">&#128269;</span>
          <input type="text" id="countrySearch" placeholder="Search countries...">
        </div>

        <form action="/groups/create/city" method="get" id="countryForm">
          <input type="hidden" name="country" id="selectedCountry" value="">
          <div class="destination-grid" id="countryGrid">
            <% if (typeof countries !== 'undefined') { %>
              <% countries.forEach(function(c) { %>
                <div class="destination-card" data-value="<%= c.name %>">
                  <div class="card-flag"><%= c.flag %></div>
                  <span class="card-name"><%= c.name %></span>
                </div>
              <% }); %>
            <% } %>
          </div>
          <div class="setup-actions" style="margin-top: 32px;">
            <button type="submit" class="btn btn-primary" id="nextBtn" disabled>Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  var cards = document.querySelectorAll('#countryGrid .destination-card');
  var selectedInput = document.getElementById('selectedCountry');
  var nextBtn = document.getElementById('nextBtn');

  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      cards.forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      selectedInput.value = card.dataset.value || '';
      nextBtn.disabled = false;
    });
  });

  document.getElementById('countrySearch').addEventListener('input', function(e) {
    var q = e.target.value.toLowerCase();
    cards.forEach(function(card) {
      var name = card.querySelector('.card-name').textContent.toLowerCase();
      card.style.display = name.includes(q) ? '' : 'none';
    });
  });

  document.getElementById('countryForm').addEventListener('submit', function(e) {
    if (!selectedInput.value) {
      e.preventDefault();
      alert('Please select a country first.');
    }
  });
</script>
</body>
</html>
