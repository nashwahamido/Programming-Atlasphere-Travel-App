<!DOCTYPE html>
<html lang="en">
  <head>

    <meta charset="UTF-8">
    <title><$= title ></title>

    <meta name="description" content="Your individual profile settings can be changed">
    <meta name="keywords" content="Your individual profile settings">
    <meta name="author" content="Group 4">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">

</head>

<body>
  <!-- include header and navbar template from partials -->
  <%- include('../partials/navbar') %>

  <!-- each page's content is injected here -->
  <div class="container-fluid">
    <%- 
        <main>
            <h1>Profile</h1>
            <!-- form to upload your own profile image - this is optional -->
            <figure class="iprofileImg">
              <img src="<% # >" alt="personal profile image" class="personalProfileImg">
            </figure>
            <form action="#" method="post" enctype="form-data">
                <label>Upload a profile picture or do it later:</label><br>
                <input type="file" id="profileimg" accept="image/*"><br>
            </form>

            <div>
                <p>user name: </p><span><% username %></span>
            </div>
            
            <div>
                <p>places visited: </p><span><% placesVisited %></span>
                <p>cities visited: </p><span><% citiesVisited %></span>
                <p>number of created groups: </p><span><% %></span>
            </div>
        </main>

    %>
  </div>

  <!-- include footer template from partials -->
  <%- include('..partials/footer') %>
  <script src="/js/bootstrap.bundle.min.js"> </script>

  
  </body>
</html>
