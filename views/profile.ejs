<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/partials.css">
  </head>
  <body>
    <%- include('partials/navbar') %>
    <main>
      <h1>Profile</h1>
      <figure class="iprofileImg">
        <img src="<%= user.profile_image || '/images/default-avatar.png' %>" alt="profile image" class="personalProfileImg">
      </figure>
      <div class="username-pill">
        <%= user.username %>
      </div>
      <div class="stats-row">
        <div class="stat">
          <p>Countries visited</p>
          <span><%= user.countries_visited || 0 %></span>
        </div>
        <div class="stat">
          <p>Planning to visit</p>
          <span><%= user.planning_to_visit || 0 %></span>
        </div>
        <div class="stat">
          <p>Number of Created Groups</p>
          <span><%= user.groups_created || 0 %></span>
        </div>
      </div>
    </main>
    <%- include('partials/footer') %>
  </body>
</html>