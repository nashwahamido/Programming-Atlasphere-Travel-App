<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8">
    <title>Profile Atlasphere</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

    <main class="profile-main">
      <h1>Profile</h1>

      <div class="profile-avatar">
        <img src="<%= image %>"
          alt="profile picture" class="avatar-img"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
        <div class="avatar-placeholder">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="35" r="20" fill="#9ab"/>
            <ellipse cx="50" cy="85" rx="30" ry="25" fill="#9ab"/>
          </svg>
        </div>
      </div>

      <div class="username-pill">
        <%= user ? user.username : 'Username' %>
      </div>

      <div class="stats-row">
        <div class="stat">
          <p>Visited:</p>
          <div class="flag-row">
            <% if (user && user.visitedCountries && user.visitedCountries.length > 0) { %>
              <% user.visitedCountries.forEach(function(flag) { %>
                <span class="flag"><%= flag %></span>
              <% }) %>
            <% } else { %>
              <span class="flag">🇮🇪</span>
              <span class="flag">🇦🇹</span>
              <span class="flag">🇮🇹</span>
            <% } %>
          </div>
        </div>

        <div class="stat">
          <p>Planning to visit:</p>
          <div class="flag-row">
            <% if (user && user.planningCountries && user.planningCountries.length > 0) { %>
              <% user.planningCountries.forEach(function(flag) { %>
                <span class="flag"><%= flag %></span>
              <% }) %>
            <% } else { %>
              <span class="flag">🏴󠁧󠁢󠁳󠁣󠁴󠁿</span>
              <span class="flag">🇳🇱</span>
              <span class="flag">🇩🇪</span>
            <% } %>
          </div>
        </div>

        <div class="stat">
          <p>Number of Created Groups</p>
          <span class="stat-number"><%= user ? (user.groups_created || 0) : 4 %></span>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>