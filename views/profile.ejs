<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8">
    <title>Profile Atlasphere</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css"/>

    <style>
      .profile-avatar {
        width: 200px;
        height: 200px;
        overflow: hidden;
        position: relative;
        cursor: pointer;
        margin: 0 auto 24px;
        border-radius: 50%;
        background-color: #c8d8e8;
      }

      .profile-avatar:hover .avatar-upload-overlay {
        opacity: 1;
      }

      .iprofileImg {
        width: 200px;
        height: 200px;
        margin: 0;
        padding: 0;
      }

      .personalProfileImg {
        width: 200px;
        height: 200px;
        object-fit: cover;
        border-radius: 50%;
        display: block;
      }

      .avatar-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .avatar-placeholder svg {
        width: 70%;
        height: 70%;
      }

      .avatar-upload-overlay {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0,0,0,0.6);
        color: #fff;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
        z-index: 2;
      }

      .profile-upload-input {
        display: none;
      }

      .fi {
        width: 48px !important;
        height: 36px !important;
        background-size: cover !important;
        border-radius: 4px;
        margin: 2px;
        display: inline-block;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

    <main class="profile-main">
      <h1>Profile</h1>

      <form action="/profile/upload" method="post" enctype="multipart/form-data" id="profileUploadForm">
        <div class="profile-avatar" onclick="document.getElementById('profilePicInput').click();">
          <% if (image) { %>
            <figure class="iprofileImg">
              <img src="<%= image %>" alt="profile picture" class="personalProfileImg" id="avatarPreview">
            </figure>
          <% } else { %>
            <div class="avatar-placeholder" id="avatarPlaceholder">
              <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="35" r="20" fill="#9ab"/>
                <ellipse cx="50" cy="85" rx="30" ry="25" fill="#9ab"/>
              </svg>
            </div>
            <figure class="iprofileImg" style="display:none;">
              <img src="" alt="profile picture" class="personalProfileImg" id="avatarPreview">
            </figure>
          <% } %>
          <span class="avatar-upload-overlay">Change photo</span>
        </div>
        <input type="file" name="profilePicture" accept="image/*" id="profilePicInput" class="profile-upload-input">
      </form>

      <div class="username-pill">
        <%= user ? user.username : 'Username' %>
      </div>

      <div class="stats-row">
        <div class="stat">
          <p>Visited:</p>
          <div class="flag-row">
            <% if (user && user.visitedCountries && user.visitedCountries.length > 0) { %>
              <% user.visitedCountries.forEach(function(country) { %>
                <span
                  class="fi fi-<%= (country.code || country).toLowerCase() %>"
                  title="<%= country.name || country %>">
                </span>
              <% }) %>
            <% } else { %>
              <span style="color: var(--text-secondary, #888); font-size: 14px;">None yet</span>
            <% } %>
          </div>
          <% if (user && user.visitedCities && user.visitedCities.length > 0) { %>
            <div style="margin-top: 8px; font-size: 13px; color: var(--text-secondary, #888);">
              <%= user.visitedCities.join(', ') %>
            </div>
          <% } %>
        </div>

        <div class="stat">
          <p>Planning to visit:</p>
          <div class="flag-row">
            <% if (user && user.planningCountries && user.planningCountries.length > 0) { %>
              <% user.planningCountries.forEach(function(country) { %>
                <span
                  class="fi fi-<%= (country.code || country).toLowerCase() %>"
                  title="<%= country.name || country %>">
                </span>
              <% }) %>
            <% } else { %>
              <span style="color: var(--text-secondary, #888); font-size: 14px;">No trips yet</span>
            <% } %>
          </div>
        </div>

        <div class="stat">
          <p>Number of Created Groups</p>
          <span class="stat-number"><%= user ? (user.groups_created || 0) : 0 %></span>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script>
      var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);
      document.getElementById('profilePicInput').addEventListener('change', function(e) {
        var file = e.target.files[0];
        if (!file) return;
        document.getElementById('profileUploadForm').submit();
      });
    </script>
  </body>
</html>