<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<nav class="auth-nav"><a href="/" class="auth-nav__brand">Atlasphere</a><a href="/auth/login" class="auth-nav__btn">Log in</a></nav>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/registration-lake.jpg" alt="Lake"></div>
    <div class="framed-box__content" style="display:flex;align-items:center;justify-content:center;">
      <div class="auth-card">
        <h1>Registration</h1>
        <% if (typeof error !== 'undefined' && error) { %><div class="msg-error"><%= error %></div><% } %>
        <form action="/auth/register" method="post">
          <div class="auth-fg"><label for="username">Name</label><input type="text" id="username" name="username" placeholder="Enter your name" required></div>
          <div class="auth-fg"><label for="useremail">Email</label><input type="email" id="useremail" name="useremail" placeholder="Enter your email" required></div>
          <div class="auth-fg"><label for="userphone">Phone</label><div class="auth-phone-row"><input type="text" class="phone-prefix" value="+353" readonly><input type="tel" id="userphone" name="userphone" placeholder="Phone number" required></div></div>
          <div class="auth-fg"><label for="gender">Gender</label><select id="gender" name="gender"><option value="">Select gender</option><option value="1">Male</option><option value="2">Female</option><option value="3">Diverse</option></select></div>
          <div class="auth-fg"><label for="psw">Password</label><input type="password" id="psw" name="psw" minlength="6" maxlength="12" placeholder="Min 6, max 12 characters" required></div>
          <button type="submit" class="auth-submit">Register</button>
        </form>
        <p>Already have an account? <a href="/auth/login">Sign in</a></p>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
</body>
</html>
