<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Atlasphere</title>

  <style>
    .lp-btn {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 14px 48px; border-radius: 30px; font-weight: 600; font-size: 1.2rem;
      text-decoration: none; cursor: pointer; transition: all 0.3s ease;
      min-width: 160px; font-family: var(--font);
      margin: 10px;
    }

    .lp-btn--orange {
      background: #E8933A; color: #fff; border: 2px solid #E8933A;
    }

    .lp-btn--orange:hover {
      background: #D4822F; border-color: #D4822F;
      transform: translateY(-2px); box-shadow: 0 6px 20px rgba(232,147,58,0.35);
    }

    #registerMainImg {
      background-image: url("/images/pietro-de-grandi-T7K4aEPoGGk-unsplash.jpg");
      height: 100vh;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    #registerContainer {
      width: 50%;
      padding: 10px;
      border-radius: 10px;
      background-color: rgba(247, 250, 255, 0.5);
      color: black;
      text-align: center;
    }
    #registerh1 {
      font-size: 2rem;
    }
    .labelStyle {
      font-size: 1.1rem;
      font-weight: bold;
    }
    input, select {
      width: 55%;
      padding: 12px;
      margin: 8px 0;
      display: inline-block;
      border: 1px solid #F7FAFF;
      border-radius: 4px;
      box-sizing: border-box;
    }
  </style>

</head>
<body>

<%- include('partials/navbar', { user: null }) %>

<main id="registerMainImg">
  <div id="registerContainer">
    <h1 id="registerh1">Register</h1>

    <form action="/auth/register" method="post">
      <label for="username" class="labelStyle">Name: </label>
      <input type="text" id="username" name="username" placeholder="Enter your name" required><br>

      <label for="useremail" class="labelStyle">Email: </label>
      <input type="email" id="useremail" name="useremail" placeholder="Enter your email" required><br>

      <label for="userphone" class="labelStyle">Phone: </label>
      <input type="tel" id="userphone" name="userphone" placeholder="Phone number" required><br>

      <label for="gender" class="labelStyle">Gender: </label>
      <select id="gender" name="gender">
        <option value="">Select gender</option>
        <option value="1">Male</option>
        <option value="2">Female</option>
        <option value="3">Diverse</option>
      </select><br>

      <label for="psw" class="labelStyle">Password (min. 6 characters, max. 12): </label><br>
      <input type="password" id="psw" name="psw" size="" minlength="6" maxlength="12" required><br>
                   
      <button type="submit" class="lp-btn lp-btn--orange">Register</button>
    </form>

    <p>Already have an account? <a href="/auth/login">Sign in</a></p>
  </div>
</main>

</body>
</html>