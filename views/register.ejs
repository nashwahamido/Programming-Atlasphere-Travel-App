<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Atlasphere</title>
</head>
<body>

<%- include('partials/navbar', { user: null }) %>

<main>
  <h1>Register</h1>

  <form action="/auth/register" method="post">
    <label for="username">Name</label>
    <input type="text" id="username" name="username" placeholder="Enter your name" required>

    <label for="useremail">Email</label>
    <input type="email" id="useremail" name="useremail" placeholder="Enter your email" required>

    <label for="userphone">Phone</label>
    <input type="tel" id="userphone" name="userphone" placeholder="Phone number" required>

    <label for="gender">Gender</label>
    <select id="gender" name="gender">
      <option value="">Select gender</option>
      <option value="m">Male</option>
      <option value="f">Female</option>
      <option value="d">Diverse</option>
    </select>

    <button type="submit">Register</button>
  </form>

  <p>Already have an account? <a href="/auth/login">Sign in</a></p>
</main>

</body>
</html>